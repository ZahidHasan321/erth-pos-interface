{
  "name": "mono-repo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "supabase": "node_modules/.bin/supabase",
    "supabase:functions:deploy": "node_modules/.bin/supabase functions deploy auth-login && node_modules/.bin/supabase functions deploy auth-admin"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "supabase": "^2.84.6",
    "turbo": "^2.7.5",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
